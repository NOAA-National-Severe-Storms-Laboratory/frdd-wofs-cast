      "File \u001b[0;32m/work/mflora/miniconda3/envs/wofs-cast/lib/python3.10/site-packages/haiku/_src/basic.py:179\u001b[0m, in \u001b[0;36mLinear.__call__\u001b[0;34m(self, inputs, precision)\u001b[0m\n\u001b[1;32m    177\u001b[0m   stddev \u001b[38;5;241m=\u001b[39m \u001b[38;5;241m1.\u001b[39m \u001b[38;5;241m/\u001b[39m np\u001b[38;5;241m.\u001b[39msqrt(\u001b[38;5;28mself\u001b[39m\u001b[38;5;241m.\u001b[39minput_size)\n\u001b[1;32m    178\u001b[0m   w_init \u001b[38;5;241m=\u001b[39m hk\u001b[38;5;241m.\u001b[39minitializers\u001b[38;5;241m.\u001b[39mTruncatedNormal(stddev\u001b[38;5;241m=\u001b[39mstddev)\n\u001b[0;32m--> 179\u001b[0m w \u001b[38;5;241m=\u001b[39m \u001b[43mhk\u001b[49m\u001b[38;5;241;43m.\u001b[39;49m\u001b[43mget_parameter\u001b[49m\u001b[43m(\u001b[49m\u001b[38;5;124;43m\"\u001b[39;49m\u001b[38;5;124;43mw\u001b[39;49m\u001b[38;5;124;43m\"\u001b[39;49m\u001b[43m,\u001b[49m\u001b[43m \u001b[49m\u001b[43m[\u001b[49m\u001b[43minput_size\u001b[49m\u001b[43m,\u001b[49m\u001b[43m \u001b[49m\u001b[43moutput_size\u001b[49m\u001b[43m]\u001b[49m\u001b[43m,\u001b[49m\u001b[43m \u001b[49m\u001b[43mdtype\u001b[49m\u001b[43m,\u001b[49m\u001b[43m \u001b[49m\u001b[43minit\u001b[49m\u001b[38;5;241;43m=\u001b[39;49m\u001b[43mw_init\u001b[49m\u001b[43m)\u001b[49m\n\u001b[1;32m    181\u001b[0m out \u001b[38;5;241m=\u001b[39m jnp\u001b[38;5;241m.\u001b[39mdot(inputs, w, precision\u001b[38;5;241m=\u001b[39mprecision)\n\u001b[1;32m    183\u001b[0m \u001b[38;5;28;01mif\u001b[39;00m \u001b[38;5;28mself\u001b[39m\u001b[38;5;241m.\u001b[39mwith_bias:\n",
      "File \u001b[0;32m/work/mflora/miniconda3/envs/wofs-cast/lib/python3.10/site-packages/haiku/_src/base.py:685\u001b[0m, in \u001b[0;36mget_parameter\u001b[0;34m(name, shape, dtype, init)\u001b[0m\n\u001b[1;32m    682\u001b[0m param \u001b[38;5;241m=\u001b[39m check_not_none(param, \u001b[38;5;124m\"\u001b[39m\u001b[38;5;124mParameters cannot be `None`.\u001b[39m\u001b[38;5;124m\"\u001b[39m)\n\u001b[1;32m    684\u001b[0m \u001b[38;5;28;01mif\u001b[39;00m param\u001b[38;5;241m.\u001b[39mshape \u001b[38;5;241m!=\u001b[39m \u001b[38;5;28mtuple\u001b[39m(shape):\n\u001b[0;32m--> 685\u001b[0m   \u001b[38;5;28;01mraise\u001b[39;00m \u001b[38;5;167;01mValueError\u001b[39;00m(\n\u001b[1;32m    686\u001b[0m       \u001b[38;5;124mf\u001b[39m\u001b[38;5;124m\"\u001b[39m\u001b[38;5;132;01m{\u001b[39;00mfq_name\u001b[38;5;132;01m!r}\u001b[39;00m\u001b[38;5;124m with retrieved shape \u001b[39m\u001b[38;5;132;01m{\u001b[39;00mparam\u001b[38;5;241m.\u001b[39mshape\u001b[38;5;132;01m!r}\u001b[39;00m\u001b[38;5;124m does not match \u001b[39m\u001b[38;5;124m\"\u001b[39m\n\u001b[1;32m    687\u001b[0m       \u001b[38;5;124mf\u001b[39m\u001b[38;5;124m\"\u001b[39m\u001b[38;5;124mshape=\u001b[39m\u001b[38;5;132;01m{\u001b[39;00mshape\u001b[38;5;132;01m!r}\u001b[39;00m\u001b[38;5;124m dtype=\u001b[39m\u001b[38;5;132;01m{\u001b[39;00mdtype\u001b[38;5;132;01m!r}\u001b[39;00m\u001b[38;5;124m\"\u001b[39m)\n\u001b[1;32m    689\u001b[0m \u001b[38;5;28;01mreturn\u001b[39;00m param\n",
      "\u001b[0;31mValueError\u001b[0m: 'grid2mesh_gnn/~_networks_builder/encoder_edges_grid2mesh_mlp/~/linear_0/w' with retrieved shape (256,) does not match shape=[4, 256] dtype=dtype(bfloat16)"
     ]
    }
   ],
   "source": [
    "%%time\n",
    "# For the time series\n",
    "#MODEL_PATH = '/work/mflora/wofs-cast-data/model/wofscast_baseline_full_v2.npz'\n",
    "MODEL_PATH = '/work/cpotvin/WOFSCAST/model/wofscast_test_v120.npz'\n",
    "\n",
    "N_SAMPLES = 100\n",
    "n_times = 12 \n",
    "rmse_dict_fname = MODEL_PATH.replace('.npz', '_rmse_N=%d.pkl' % N_SAMPLES)\n",
    "cont_dict_fname = MODEL_PATH.replace('.npz', '_cont_N=%d.pkl' % N_SAMPLES)\n",
    "compute_verif = False#True\n",
    "\n",
    "if compute_verif or not os.path.exists(rmse_dict_fname) or not os.path.exists(cont_dict_fname):\n",
    "\n",
    "    model = WoFSCastModel()\n",
    "\n",
    "    model.load_model(MODEL_PATH, use_transformer=False)#, k_hop=8, num_attn_heads=4)\n",
    "\n",
    "    rmse_dict = { 'full' : {v : np.zeros((n_times,)) for v in target_vars},\n",
    "              'partial' : {v : np.zeros((n_times,)) for v in target_vars},\n",
    "            }\n",
    "\n",
    "    cont_dict = {metric : np.zeros((n_times)) for metric in ['hits', 'misses', 'false_alarms']}\n",
    "\n",
    "\n",
    "    # Selecting a single ensemble member. \n",
    "    base_path = '/work/mflora/wofs-cast-data/datasets_2hr_zarr/2021/*_ens_mem_09.zarr'\n",
    "    paths = glob(base_path)\n",
    "    paths.sort()\n",
    "\n",
    "    rs = np.random.RandomState(42)\n",
    "    random_paths = rs.choice(paths, size=N_SAMPLES, replace=False)\n",
    "\n",
    "    N = len(random_paths)\n",
    "\n",
    "    for n, path in enumerate(random_paths):\n",
    "        print (n)\n",
    "        dataset = xarray.load_dataset(path)\n",
    "\n",
    "        inputs, targets, forcings = model.get_inputs(dataset)\n",
    "        predictions = model.predict(inputs, targets, forcings)\n",
    "        #predictions = predictions.transpose('batch', 'time', 'level', 'lat', 'lon')\n",
    "        predictions = predictions.transpose('batch', 'time',  'lat', 'lon')\n",
    "\n",
    "        rmse_dict = accumulate_rmse(targets, predictions, target_vars, rmse_dict)\n",
    "\n",
    "        results = [process_time_step(predictions.isel(time=t, batch=0), targets.isel(time=t, batch=0))\n",
    "              for t in np.arange(n_times)]\n",
    "    \n",
    "        for t, result in enumerate(results):\n",
    "            for key in cont_dict.keys():\n",
    "                cont_dict[key][t] += result[key]\n",
    "    \n",
    "    \n",
    "    for key in rmse_dict.keys():\n",
    "        for v in target_vars:\n",
    "            rmse_dict[key][v]/=N\n",
    "\n",
    "    with open(rmse_dict_fname, 'wb') as file:\n",
    "        pickle.dump(rmse_dict, file)\n",
    "    with open(cont_dict_fname, 'wb') as file:\n",
    "        pickle.dump(cont_dict, file)\n",
    "    \n",
    "else:\n",
    "    \n",
    "    with open(rmse_dict_fname, 'rb') as file:\n",
    "       rmse_dict = pickle.load(file) \n",
    "    with open(cont_dict_fname, 'rb') as file:\n",
    "       cont_dict = pickle.load(file) "
   ]
  },
